---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const page = await getEntry("pages", "astro-review");
if (!page) {
  throw new Error("Astro review page not found");
}
const sections = page.data.sections ?? [];
const cards = page.data.cards ?? [];
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="astro-hero full-screen">
    <div>
      <p class="eyebrow">Astro + Cloudflare</p>
      <h1>{page.data.heroTitle}</h1>
      <p>{page.data.heroText}</p>
    </div>

    {page.data.heroImage ? (
      <img class="showcase-image large" src={page.data.heroImage} alt={page.data.heroTitle} />
    ) : (
      <div class="image-placeholder large">{page.data.heroImageLabel ?? "Hero image placeholder"}</div>
    )}
  </section>

  {sections.map((section, index) => (
    <section class="split-section">
      {index % 2 === 0 && (
        section.image ? (
          <img class="showcase-image" src={section.image} alt={section.title} />
        ) : (
          <div class="image-placeholder">{section.imageLabel ?? "Image placeholder"}</div>
        )
      )}

      <div>
        {section.eyebrow && <p class="eyebrow">{section.eyebrow}</p>}
        <h2>{section.title}</h2>
        <p>{section.text}</p>
      </div>

      {index % 2 !== 0 && (
        section.image ? (
          <img class="showcase-image" src={section.image} alt={section.title} />
        ) : (
          <div class="image-placeholder">{section.imageLabel ?? "Image placeholder"}</div>
        )
      )}
    </section>
  ))}

  <section class="feature-grid">
    {cards.map((card) => (
      <article>
        {card.image ? (
          <img class="showcase-image small" src={card.image} alt={card.title} />
        ) : (
          <div class="image-placeholder small">{card.imageLabel ?? "Image"}</div>
        )}
        <h3>{card.title}</h3>
        <p>{card.text}</p>
      </article>
    ))}
  </section>
</BaseLayout>