---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Cloudflare Astro Demo"
  description="A modern publishing platform for business teams."
>
  <section class="home-hero">
    <div class="hero-orb orb-one"></div>
    <div class="hero-orb orb-two"></div>

    <div class="home-hero-content">
      <p class="eyebrow">Astro · Cloudflare · GitHub · Decap CMS</p>
      <h1>
        Modern publishing for business teams without handing over the keys.
      </h1>
      <p>
        A fast public website, a simple content editor, secure GitHub-backed
        publishing, and R2-powered media delivery — all managed through
        Cloudflare.
      </p>

      <div class="home-actions">
        <a href="/astro-review" class="primary-cta">Explore the Architecture</a>
        <a href="/decap-demo" class="secondary-cta">See CMS Workflow</a>
      </div>
    </div>

    <div class="hero-panel">
      <div class="browser-bar">
        <span></span><span></span><span></span>
      </div>
      <div class="flow-card is-active" data-step="0">
        Business user edits content
      </div>
      <div class="flow-card" data-step="1">Decap commits to GitHub</div>
      <div class="flow-card" data-step="2">Cloudflare deploys Worker</div>
      <div class="flow-card" data-step="3">R2 serves media</div>
    </div>
  </section>

  <section class="parallax-band">
    <div>
      <h2>Content changes are easy. Layout changes stay controlled.</h2>
      <p>
        Business users can update text, images, and resource links. Developers
        keep ownership of templates, components, styling, security, and
        deployment.
      </p>
    </div>
  </section>

  <section class="demo-grid">
    <article>
      <span>01</span>
      <h3>Static speed</h3>
      <p>
        Astro keeps the public site lightweight, fast, and optimized for
        content-heavy pages.
      </p>
    </article>

    <article>
      <span>02</span>
      <h3>Simple editing</h3>
      <p>
        Decap CMS gives non-technical users forms instead of Git commands or
        code changes.
      </p>
    </article>

    <article>
      <span>03</span>
      <h3>Media offload</h3>
      <p>
        Cloudflare R2 stores PDFs, images, downloads, and other files outside
        the repo.
      </p>
    </article>

    <article>
      <span>04</span>
      <h3>IT governance</h3>
      <p>
        GitHub, Cloudflare, and controlled templates preserve auditability and
        ownership.
      </p>
    </article>
  </section>

  <section class="timeline-section">
    <h2>Publishing flow</h2>

    <div class="timeline">
      <div>
        <strong>1</strong>
        <h3>Edit</h3>
        <p>Business users update CMS fields or upload media.</p>
      </div>

      <div>
        <strong>2</strong>
        <h3>Commit</h3>
        <p>Decap writes structured Markdown changes to GitHub.</p>
      </div>

      <div>
        <strong>3</strong>
        <h3>Deploy</h3>
        <p>Cloudflare builds and publishes the updated site.</p>
      </div>

      <div>
        <strong>4</strong>
        <h3>Serve</h3>
        <p>Visitors get fast pages and R2-hosted downloads.</p>
      </div>
    </div>
  </section>

  <script>
    const hero = document.querySelector(".home-hero") as HTMLElement | null;
    const flowCards = Array.from(document.querySelectorAll(".flow-card"));

    window.addEventListener("scroll", () => {
      if (!hero) return;

      const rect = hero.getBoundingClientRect();
      const progress = Math.min(
        1,
        Math.max(0, Math.abs(rect.top) / window.innerHeight),
      );

      hero.style.setProperty("--hero-parallax-y", `${progress * 90}px`);

      const activeIndex = Math.min(
        flowCards.length - 1,
        Math.floor(progress * flowCards.length),
      );

      flowCards.forEach((card, index) => {
        card.classList.toggle("is-active", index === activeIndex);
      });
    });
  </script>
</BaseLayout>